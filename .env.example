# Optional. Get a free key at https://console.groq.com/keys
# If left unset, the agent runs fully offline using a deterministic
# fallback generator (see agent/llm_client.py) -- no cost, no signup required.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Where generated .docx files are written
OUTPUT_DIR=generated_docs
